# Copy this file to .env and fill in your values.

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                              # DEBUG | INFO | WARNING | ERROR

# ── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=<your_anthropic_api_key>
MODEL_NAME=claude-sonnet-4-5-20250929       # research agent (triage/validation use Haiku)

# ── Embeddings ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=<your_openai_api_key>
EMBEDDING_MODEL=text-embedding-3-small

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K=3

# ── Memory ────────────────────────────────────────────────────────────────────
MEMORY_MAX_PAIRS=5                          # recent Q/A pairs kept per session

# ── Paths ─────────────────────────────────────────────────────────────────────
# Root of the on-disk data layout; per-collection/per-PDF paths are composed
# from this (see src/registry.py): data/<collection>/{chroma, <doc_id>/...}
DATA_DIR=data

# ── LangSmith (optional tracing) ──────────────────────────────────────────────
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=<your_langsmith_api_key>
LANGSMITH_PROJECT=<your_langsmith_project>
